# Copy to .env and fill in values (never commit .env)
SPRING_PROFILES_ACTIVE=production
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
APP_JWT_SECRET=change-me-to-a-long-random-secret-min-256-bits
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:3000
