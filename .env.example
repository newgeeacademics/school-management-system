# Main app (repo root) — landing, registration, /login, /dashboard
# Optional in local dev (defaults to http://localhost:8080). Required on Vercel production override.
VITE_API_URL=http://localhost:8080
VITE_USER_PORTAL_URL=http://localhost:5174

# Production examples:
# VITE_API_URL=https://school-management-system-gw9s.onrender.com
# Or omit VITE_API_URL — vercel.json proxies /api to Render (recommended on www.newgeeacademy.com)
# VITE_USER_PORTAL_URL=https://portal.newgeeacademy.com
