# Development Environment Configuration Example
# Copy this file to .env and update with your local development values

# Backend API Base URL (dev only - localhost)
VITE_BACKEND_BASE_URL=http://localhost:3000
VITE_API_URL=http://localhost:3000

# Authentication Token Keys (dev only)
VITE_ACCESS_TOKEN_KEY=dev_access_token
VITE_REFRESH_TOKEN_KEY=dev_refresh_token

# Cloudinary Configuration (dev only - use your dev account or leave empty)
VITE_CLOUDINARY_UPLOAD_URL=https://api.cloudinary.com/v1_1/YOUR_CLOUD_NAME/image/upload
VITE_CLOUDINARY_CLOUD_NAME=your_dev_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_dev_preset

# Environment
NODE_ENV=development
